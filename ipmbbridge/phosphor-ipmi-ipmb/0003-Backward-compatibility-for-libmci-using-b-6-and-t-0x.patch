From 6693c669b6b0d0d7497694f03ad6d3b20541d6cf Mon Sep 17 00:00:00 2001
From: Jacob Chen <jacob.chen@insyde.com>
Date: Tue, 10 Feb 2026 03:46:44 -0500
Subject: [PATCH] Backward compatibility for libmci using -b 6 and -t 0x2C

Since the new design restricts -t option to [1, 31], if now the user
wants to use -t value exceeding this internal, then the ipmb switchs to
the mode of directly indexing among ipmb-channels.json using the value,
instead of treating it as devIndex; but on the other hand, the user
could ONLY have ONE json entry with devIndex being 0 (or no devIndex)
__that meets this type of usage__. This very entry uses the remote-addr
as the legacy way as "target device's remote address".

Signed-off-by: Jacob Chen <jacob.chen@insyde.com>
---
 ipmbbridged.cpp | 37 +++++++++++++++++++++++++++++--------
 1 file changed, 29 insertions(+), 8 deletions(-)

diff --git a/ipmbbridged.cpp b/ipmbbridged.cpp
index d28d087..40f5e69 100644
--- a/ipmbbridged.cpp
+++ b/ipmbbridged.cpp
@@ -1004,15 +1004,36 @@ static IpmbChannel *getChannel(uint8_t reqChannel, uint8_t addr)
         rqChnlT != ipmbChannelType::ipmb)
         return nullptr;
 
-    uint8_t reqidx = ((addr << 3) | (reqChannel % 5));
-                std::string amsgToLog;
-    auto channel =
-        std::find_if(ipmbChannels.begin(), ipmbChannels.end(),
-                     [reqidx](IpmbChannel &channel) {
-                         return channel.getChannelIdx() == reqidx;
-                     });
+    auto channel = ipmbChannels.end();
+    if (addr <= 32) { // 1 ~ 31
+        uint8_t reqidx = (((addr-1) << 3) | (reqChannel % 5));
+        channel =
+            std::find_if(ipmbChannels.begin(), ipmbChannels.end(),
+                         [reqidx](IpmbChannel &channel) {
+                             return
+                                 reqidx
+                                        == channel.getChannelIdx();
+                         });
+    } else { // >= 33, e.g. 0x2C. Restricted from here & after.
+        channel =
+            std::find_if(ipmbChannels.begin(), ipmbChannels.end(),
+                         [addr, rqChnlT](IpmbChannel &channel) {
+                             return
+                                 rqChnlT
+                                        == channel.getChannelType() &&
+                                 addr
+                                        == channel.getRqSlaveAddress() &&
+                                 0
+                                        == channel.getDevIndex();
+                         });
+    }
+
     if (channel != ipmbChannels.end())
     {
+                std::string msgToLog;
+                msgToLog += "new getChannel: found entry" ;
+                phosphor::logging::log<phosphor::logging::level::ERR>(
+                    msgToLog.c_str());
         return &(*channel);
     }
 
@@ -1162,7 +1183,7 @@ auto ipmbHandleRequestWithAddress = [](boost::asio::yield_context yield,
                                        uint8_t reqChannel, uint8_t netfn,
                                        uint8_t lun, uint8_t cmd, uint8_t addr,
                                        std::vector<uint8_t> dataReceived) {
-    IpmbChannel *channel = getChannel(reqChannel, addr-1);
+    IpmbChannel *channel = getChannel(reqChannel, addr);
 
     if (channel == nullptr)
     {
-- 
2.34.1

