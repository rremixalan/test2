From e94208b908fd9b91c14e3424401edd6926eb13bf Mon Sep 17 00:00:00 2001
From: Jacob Chen <jacob.chen@insyde.com>
Date: Wed, 4 Feb 2026 11:58:32 -0500
Subject: [PATCH] Use b option in ipmitool bridge command as channel number

Signed-off-by: Jacob Chen <jacob.chen@insyde.com>
---
 include/bridgingcommands.hpp | 2 +-
 src/bridgingcommands.cpp     | 5 +++--
 2 files changed, 4 insertions(+), 3 deletions(-)

diff --git a/include/bridgingcommands.hpp b/include/bridgingcommands.hpp
index 534c7e0..fb3bdbb 100644
--- a/include/bridgingcommands.hpp
+++ b/include/bridgingcommands.hpp
@@ -199,7 +199,7 @@ class Bridging
     void clearResponseQueue();
 
     ipmi::Cc handleIpmbChannel(ipmi::Context::ptr ctx, const uint8_t tracking,
-                               const std::vector<uint8_t>& msgData,
+                               const uint8_t channelNo, const std::vector<uint8_t>& msgData,
                                std::vector<uint8_t>& rspData);
 
     void insertMessageInQueue(IpmbResponse msg);
diff --git a/src/bridgingcommands.cpp b/src/bridgingcommands.cpp
index 43793eb..f7eb79c 100644
--- a/src/bridgingcommands.cpp
+++ b/src/bridgingcommands.cpp
@@ -254,6 +254,7 @@ static constexpr bool isMeCmdAllowed(uint8_t netFn, uint8_t cmd)
 
 ipmi::Cc Bridging::handleIpmbChannel(ipmi::Context::ptr ctx,
                                      const uint8_t tracking,
+                                     const uint8_t channelNo,
                                      const std::vector<uint8_t>& msgData,
                                      std::vector<uint8_t>& rspData)
 {
@@ -322,7 +323,7 @@ ipmi::Cc Bridging::handleIpmbChannel(ipmi::Context::ptr ctx,
     boost::system::error_code ec;
     auto ipmbResponse = ctx->bus->yield_method_call<IPMBResponse>(
         ctx->yield, ec, ipmbBus, ipmbObj, ipmbIntf, "sendRequestToAddress",
-        ipmbMeChannelNum, ipmbRequest.netFn, ipmbRequest.rqLun, ipmbRequest.cmd,
+        channelNo, ipmbRequest.netFn, ipmbRequest.rqLun, ipmbRequest.cmd,
         ipmbRequest.address, ipmbRequest.data);
     if (ec)
     {
@@ -457,7 +458,7 @@ ipmi::RspType<std::vector<uint8_t> // responseData
     }
 
     returnVal = bridging.handleIpmbChannel(
-        ctx, static_cast<const uint8_t>(tracking), unpackMsg, rspData);
+        ctx, static_cast<const uint8_t>(tracking), channelNo, unpackMsg, rspData);
     if (returnVal != ipmi::ccSuccess)
     {
         return ipmi::response(returnVal);
-- 
2.34.1

